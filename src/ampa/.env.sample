# Sample environment file for local testing. DO NOT commit real secrets.
# Copy this to ampa/.env and set your bot credentials. DO NOT commit real secrets.
# The project formerly used a Discord webhook; the current delivery model uses a
# Discord bot token and a channel ID. Set both values below (keep quotes if you
# want them preserved). Example placeholders are safe to commit but must be
# replaced in any real deployment.
#
# AMPA_DISCORD_BOT_TOKEN — Bot token for the notification bot (secret)
# AMPA_DISCORD_CHANNEL_ID — Numeric channel id to post notifications into
AMPA_DISCORD_BOT_TOKEN="<your-bot-token-here>"
AMPA_DISCORD_CHANNEL_ID="<your-channel-id-here>"

# Test / CI channel override
# AMPA_DISCORD_TEST_CHANNEL_ID — If set, the bot will attempt to route test notifications
# to this channel instead of the default AMPA_DISCORD_CHANNEL_ID. This is useful
# when you want tests to post to a separate channel to avoid polluting the
# production ops channel with test noise.
# Note: This env var sets a *default* test channel for messages that do not
# specify a per-message channel override. Per-message overrides via the
# `channel_id` argument to `ampa.notifications.notify()` take precedence.
# AMPA_DISCORD_TEST_CHANNEL_ID="<your-test-channel-id-here>"

# CI / dry-run mode
# AMPA_DISABLE_DISCORD — If set to any non-empty value, the notification system
# becomes a no-op: notify() returns True without sending messages to Discord.
# This is intended for CI environments where you want to exercise the
# notification path (e.g. to verify payloads and logging) without actually
# posting to Discord. The bot also respects this flag in _send_to_discord().
# AMPA_DISABLE_DISCORD="1"

# How often to send heartbeats (minutes)
AMPA_HEARTBEAT_MINUTES=5

# Retry / backoff configuration for notification delivery
# AMPA_MAX_RETRIES — Maximum number of send attempts (default 10, minimum 1)
# AMPA_BACKOFF_BASE_SECONDS — Base delay in seconds for exponential backoff (default 2)
# AMPA_MAX_RETRIES=10
# AMPA_BACKOFF_BASE_SECONDS=2
